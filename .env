# ============================================================
# .env — Copy this file and fill in your actual keys
# ============================================================

# Choose your LLM provider: "openai" or "anthropic"
LLM_PROVIDER=anthropic

# API Keys (fill in the one you use)
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Path to your Identity Manager help documents folder
DOCS_FOLDER=./docs

# Vector DB persistence folder
VECTOR_DB_PATH=./vector_store

# Chunking settings
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Number of relevant chunks to retrieve per query
TOP_K_RESULTS=5
